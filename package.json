{
  "name": "cc-init",
  "version": "0.1.0",
  "description": "Scan a project and generate best-practice .claude/ configuration for Claude Code",
  "type": "module",
  "bin": {
    "cc-init": "./bin/cc-init.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "claude",
    "claude-code",
    "setup",
    "cli",
    "scaffolding"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@inquirer/prompts": "^8.4.3",
    "commander": "^14.0.3"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.7"
  }
}
